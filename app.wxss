page {
  background: #f6f7fb;
  color: #1f2937;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.btn-primary {
  background: #2f80ed;
  color: #fff;
  border-radius: 16rpx;
}

.btn-danger {
  background: #ef4444;
  color: #fff;
  border-radius: 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  margin: 16rpx 0;
}

.muted {
  color: #6b7280;
}
