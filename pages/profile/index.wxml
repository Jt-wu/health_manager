<view class="container">
  <view class="card">
    <view class="section-title">档案</view>
    <view>身高：{{profile.height || '-'}} cm</view>
    <view>体重：{{profile.weight || '-'}} kg</view>
    <view>性别：{{profile.sex || '-'}}</view>
    <view>运动水平：{{profile.activity_level || '-'}}</view>
    <view>管理目标：{{(profile.goals && profile.goals.length) ? profile.goals.join('、') : '-'}}</view>
    <view>主目标：{{profile.primaryGoal || '-'}}</view>
    <view>血压：{{profile.bp || '-'}}</view>
    <view>尿酸：{{profile.ua || '-'}}</view>
    <view>血脂：{{profile.lipid || '-'}}</view>
    <view>过敏原：{{(profile.allergies && profile.allergies.length) ? profile.allergies.join('、') : '-'}}</view>
    <view>忌口：{{(profile.avoid_foods && profile.avoid_foods.length) ? profile.avoid_foods.join('、') : '-'}}</view>
    <button bindtap="goOnboarding" style="margin-top:12rpx;">编辑档案</button>
  </view>

  <view class="card">
    <view class="section-title">Plus 订阅</view>
    <view>{{plusStatus ? '已开通 Plus' : '未开通 Plus'}}</view>
    <button bindtap="togglePlus" style="margin-top:12rpx;">{{plusStatus ? '取消（演示）' : '开通（演示）'}}</button>
  </view>

  <view class="card">
    <view class="section-title">免责声明</view>
    <view class="muted">本产品用于健康管理与饮食建议，不替代医疗诊断或治疗。如有不适或指标异常，请及时咨询医生/营养师。</view>
  </view>
</view>
