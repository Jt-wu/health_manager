<view class="container">
  <view class="card" wx:if="{{loading}}">识别中，请稍候...</view>

  <block wx:else>
    <view class="card">
      <view class="section-title">本餐汇总</view>
      <view>总热量：{{summary.kcal}} kcal</view>
      <view>钠：{{summary.sodium}} mg</view>
      <view>结论：{{conclusion}}</view>
      <view wx:for="{{advice}}" wx:key="*this" class="muted">- {{item}}</view>
    </view>

    <view class="card">
      <view class="section-title">菜品列表</view>
      <view wx:for="{{dishes}}" wx:key="id" style="border-bottom:1px solid #f1f5f9;padding:12rpx 0;">
        <view>{{item.name}}（{{item.cookMethod}}）</view>
        <view class="muted">份量：{{item.finalGrams}}g（自动：{{item.baseGrams}}g）</view>
        <view style="display:flex; gap:12rpx; margin-top:8rpx;">
          <button size="mini" data-id="{{item.id}}" data-size="small" bindtap="adjustSize">小(0.75x)</button>
          <button size="mini" data-id="{{item.id}}" data-size="medium" bindtap="adjustSize">中(1x)</button>
          <button size="mini" data-id="{{item.id}}" data-size="large" bindtap="adjustSize">大(1.3x)</button>
          <button size="mini" data-id="{{item.id}}" bindtap="removeDish">删除</button>
        </view>
      </view>
      <button bindtap="addDish">新增菜品</button>
    </view>

    <button class="btn-primary" bindtap="saveMeal">保存本餐</button>
  </block>
</view>
