.container { padding: 24rpx; background: #f8fafc; min-height: 100vh; }
.card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; }
.section-title { font-weight: 600; margin-bottom: 12rpx; }
.muted { color: #64748b; margin-top: 4rpx; }

.dish-row {
  border-bottom: 1px solid #f1f5f9;
  padding: 16rpx 0;
}

.editor-label {
  color: #334155;
  font-size: 24rpx;
  margin-bottom: 6rpx;
}

.input-field,
.picker-field {
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  color: #334155;
}
