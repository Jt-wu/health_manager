<view class="container" wx:if="{{editableMeal}}">
  <view class="card">
    <view class="section-title">餐次信息</view>
    <picker mode="selector" range="{{mealTypes}}" value="{{mealTypeIndex}}" bindchange="onMealTypeChange">
      <view class="picker-field">餐别：{{editableMeal.mealType}}</view>
    </picker>
    <view class="muted">{{editableMeal.time}}</view>
    <view style="margin-top:10rpx;">总热量：{{editableMeal.summary.kcal}} kcal</view>
    <view>钠：{{editableMeal.summary.sodium}} mg</view>
    <view>结论：{{editableMeal.conclusion}}</view>
  </view>

  <view class="card" wx:if="{{editableMeal.imageUrl}}">
    <view class="section-title">原始图片</view>
    <image src="{{editableMeal.imageUrl}}" mode="widthFix" style="width:100%;border-radius:16rpx;" />
  </view>

  <view class="card">
    <view class="section-title">菜品明细（可修改）</view>
    <view wx:for="{{editableMeal.dishes}}" wx:key="id" class="dish-row">
      <view class="editor-label">菜品名称</view>
      <input class="input-field" value="{{item.name}}" data-id="{{item.id}}" bindblur="onDishNameInput" placeholder="请输入菜名" />

      <view class="editor-label" style="margin-top:10rpx;">烹饪方式</view>
      <picker mode="selector" range="{{cookMethods}}" value="{{item.cookMethodIndex}}" data-id="{{item.id}}" bindchange="onCookMethodChange">
        <view class="picker-field">{{item.cookMethod}}</view>
      </picker>

      <view class="editor-label" style="margin-top:10rpx;">分量(g)</view>
      <input class="input-field" type="number" value="{{item.finalGrams}}" data-id="{{item.id}}" bindblur="onFinalGramsInput" />
    </view>
  </view>

  <view class="card">
    <view class="section-title">建议</view>
    <view wx:for="{{editableMeal.advice}}" wx:key="*this" class="muted">- {{item}}</view>
  </view>

  <button class="btn-primary" bindtap="saveChanges">保存修改</button>
</view>
