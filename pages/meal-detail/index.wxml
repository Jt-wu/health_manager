<view class="container" wx:if="{{meal}}">
  <view class="card">
    <view class="section-title">{{meal.mealType}} · {{meal.conclusion}}</view>
    <view class="muted">{{meal.time}}</view>
    <image wx:if="{{meal.imageUrl}}" src="{{meal.imageUrl}}" mode="widthFix" style="width:100%; margin-top:12rpx; border-radius:12rpx;" />
  </view>

  <view class="card">
    <view class="section-title">营养汇总</view>
    <view>热量：{{meal.summary.kcal}} kcal</view>
    <view>钠：{{meal.summary.sodium}} mg</view>
    <view>蛋白：{{meal.summary.protein}} g</view>
  </view>

  <view class="card">
    <view class="section-title">建议</view>
    <view wx:for="{{meal.advice}}" wx:key="*this" class="muted">- {{item}}</view>
  </view>

  <view class="card">
    <view class="section-title">菜品明细</view>
    <view wx:for="{{meal.dishes}}" wx:key="id" style="padding:8rpx 0; border-bottom:1px solid #f1f5f9;">
      <view>{{item.name}}（{{item.cookMethod}}）</view>
      <view class="muted">份量：{{item.finalGrams}}g</view>
    </view>
  </view>
</view>

<view class="container" wx:else>
  <view class="card">
    <view class="muted">未找到该餐次，可能已被删除。</view>
  </view>
</view>
